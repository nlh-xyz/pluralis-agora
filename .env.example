# Copy to .env and fill in. run-agora.sh auto-sources this file.

# --- Required ---
# HuggingFace access token (maps to agora_cli.py --token)
HF_TOKEN=

# --- Optional ---
# Contact email (maps to --email)
AGORA_EMAIL=

# Ports. Leave blank to use the CLI default (49200 + gpu_id) for both.
# On NAT'd hosts (e.g. Vast.ai) the announce port is the EXTERNAL mapped port and
# differs from host_port. If left blank it's auto-detected from
# VAST_TCP_PORT_<host_port> when present; on other NAT providers set it manually.
AGORA_HOST_PORT=
AGORA_ANNOUNCE_PORT=

# GPU to use (maps to --gpu_id). Default: 0
AGORA_GPU_ID=0

# Where to clone / find the agora repo. Default: ./agora next to the script.
AGORA_DIR=

# Virtualenv location (deps install here; created if missing). Default: ./.venv
AGORA_VENV=

# Seconds between retries when the network gate is full. Default: 10
AGORA_RETRY_INTERVAL=10

# Seconds to wait when we're already holding a slot in the authorization queue.
# Longer than the retry interval so we don't churn our queue position. Default: 90
AGORA_QUEUE_BACKOFF=90

# Clone source. Default: https://github.com/PluralisResearch/agora
AGORA_REPO_URL=
